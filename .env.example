APP_NAME=DisparaGO
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_PUBLIC_URL=http://localhost:8080
APP_READ_TIMEOUT=15
APP_WRITE_TIMEOUT=15
APP_SHUTDOWN_TIMEOUT=10

LOG_LEVEL=info
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-superadmin
AUTH_SECRET=change-this-secret
AUTH_TOKEN_TTL_HOURS=12
HUMANIZER_ENABLED=true
HUMANIZER_INITIAL_DELAY_MIN_SECONDS=3
HUMANIZER_INITIAL_DELAY_MAX_SECONDS=8
HUMANIZER_BASE_DELAY_MIN_SECONDS=9
HUMANIZER_BASE_DELAY_MAX_SECONDS=18
HUMANIZER_PROVIDER_DELAY_MIN_MS=1500
HUMANIZER_PROVIDER_DELAY_MAX_MS=5000
HUMANIZER_BURST_SIZE_MIN=4
HUMANIZER_BURST_SIZE_MAX=8
HUMANIZER_BURST_PAUSE_MIN_SECONDS=45
HUMANIZER_BURST_PAUSE_MAX_SECONDS=120
WEBHOOK_TOKEN_SECRET=change-this-webhook-secret
WEBHOOK_DEFAULT_SUBSCRIPTIONS=ALL
RETRY_MAX_ATTEMPTS=3
RETRY_DELAY_SECONDS=15

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/disparago?sslmode=disable
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_CAMPAIGN_MESSAGES=queue:campaign-messages

EVOLUTIONGO_BASE_URL=http://localhost:8081
EVOLUTIONGO_API_KEY=change-me
EVOLUTIONGO_TIMEOUT=30
